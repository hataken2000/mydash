{
  "manifest_version": 3,
  "name": "MyDash Slack Sender",
  "version": "1.0",
  "description": "MyDashからSlackに自動送信する拡張機能",
  "permissions": ["tabs", "scripting", "tabGroups"],
  "host_permissions": [
    "https://app.slack.com/*",
    "https://*.slack.com/*",
    "file://*/*",
    "https://hataken2000.github.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["file://*/*", "https://hataken2000.github.io/*"],
      "js": ["content-mydash.js"],
      "run_at": "document_idle"
    }
  ]
}
